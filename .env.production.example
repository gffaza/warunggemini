# Copy to .env.production — NEVER commit filled values.
# Full guide: DEPLOY.md

# --- Build-time (baked into client bundle — required for `docker build`) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Runtime only (Cloud Run env / Secret Manager — NOT in Docker image) ---
GEMINI_API_KEY=
# Minified single-line JSON from Firebase Console → Service accounts → Generate key
FIREBASE_SERVICE_ACCOUNT_JSON=
